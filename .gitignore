# dependencies (the trailing-slash form misses a node_modules symlink in a worktree)
node_modules/
node_modules

# secrets
.env.local
.env*.local

# build output
.next/
dist/
out/
*.tsbuildinfo

# playwright / test artifacts
playwright-report/
test-results/
*.log

# cloned target repos live inside memory — never track them
.autoqa/**/repo/

# transient live-run frames streamed to the cockpit during a run
.autoqa/**/run/

# PR-trigger dedup state (per-machine runtime: which PR head SHAs were already reviewed)
.autoqa/triggers.json

# Claude Code local state / transient worktrees
.claude/worktrees/

# OS
.DS_Store
