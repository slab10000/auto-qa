# Local coordinator mode.
# demo: write deterministic local artifacts for the hackathon demo.
# google: call Gemini Managed Agents when manual triggers are clicked.
AUTOQA_AGENT_MODE=demo

# Required for AUTOQA_AGENT_MODE=google.
GEMINI_API_KEY=
AUTOQA_REPO_URL=https://github.com/your-org/your-repo
AUTOQA_MAIN_BRANCH=main
AUTOQA_AGENT=antigravity-preview-05-2026
AUTOQA_INTERACTIONS_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/interactions

# Optional for private GitHub repositories.
# Use a fine-grained PAT with read-only contents access for the target repo.
AUTOQA_GITHUB_PAT=
