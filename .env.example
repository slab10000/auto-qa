# Gemini API key — get one at https://aistudio.google.com/api-keys
GEMINI_API_KEY=your_key_here

# Optional: a DEDICATED GitHub bot token (NOT your personal gh login).
# When set, EVERY PR review comment is authored by this token's account: the remote
# managed agent posts it from inside its sandbox, and if that fails the local `gh`
# fallback posts as the same bot too (GH_TOKEN overrides your stored gh login) — so a
# comment is never accidentally posted as you. Use a fine-grained token scoped to ONLY
# the target repo with "Pull requests: write", and a short expiry — it is sent to
# Google's remote-agent sandbox to make the primary GitHub API call.
# When unset, the review is posted locally via your personal `gh` CLI instead (default).
# AUTOQA_BOT_TOKEN=github_pat_xxx