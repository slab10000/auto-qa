# Gemini API key — get one at https://aistudio.google.com/api-keys
GEMINI_API_KEY=your_key_here

# Optional: a DEDICATED GitHub bot token (NOT your personal gh login).
# When set, the remote managed agent posts the PR review comment itself, from inside
# its sandbox, authored by whatever account owns this token. Use a fine-grained token
# scoped to ONLY the target repo with "Pull requests: write", and a short expiry —
# it is sent to Google's remote-agent sandbox to make the GitHub API call.
# When unset, the review is posted locally via your `gh` CLI instead (default).
# AUTOQA_BOT_TOKEN=github_pat_xxx